# Copier vers .env — mot de passe fort requis par OpenSearch 2.12+ (maj., min., chiffre, spécial, ≥ 8 car.)
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe1!

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=ChangeMe1!
OPENSEARCH_ENABLED=true

# Index Fluent Bit (état serveur : santé, logs conteneurs, métriques host)
FLUENT_BIT_OPENSEARCH_INDEX=microcrm-server-state

# Index SIEM (journal d'accès API, événements CI)
FLUENT_BIT_SECURITY_INDEX=microcrm-security-events
OPENSEARCH_SECURITY_ACCESS_LOG=true

# Adresse du collecteur Fluent Bit pour le logging driver Docker (back/front)
# Linux / WSL : 172.17.0.1:24224 (passerelle bridge par défaut)
# Docker Desktop (Mac/Win) : host.docker.internal:24224
FLUENTD_ADDRESS=172.17.0.1:24224
